# Database Configuration
DATABASE_URL=your_database_connection_string_here
PGHOST=your_pg_host
PGPORT=your_pg_port
PGUSER=your_pg_user
PGPASSWORD=your_pg_password
PGDATABASE=your_pg_database

# Authentication
SESSION_SECRET=your_session_secret_here

# OpenAI Integration
OPENAI_API_KEY=sk-your_openai_api_key_here

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_your_stripe_secret_key_here
VITE_STRIPE_PUBLIC_KEY=pk_your_stripe_publishable_key_here

# Replit Configuration (Auto-provided)
REPL_ID=your_repl_id
ISSUER_URL=https://replit.com/oidc
REPLIT_DOMAINS=your_replit_domain.repl.co
# Ayrshaer CMS Environment Configuration
# Copy this file to .env and update values for your environment

# =================================
# APPLICATION CONFIGURATION
# =================================

# Application Environment
# Options: development, production, test
NODE_ENV=development

# Server Configuration
# Port for the application (Replit uses 5000 by default)
# In production, this maps to ports 80/443
PORT=5000

# Application Base URL (used for OAuth redirects)
# Development: http://localhost:5000
# Production: https://your-repl-name.replit.app
BASE_URL=http://localhost:5000

# =================================
# DATABASE CONFIGURATION
# =================================

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database
# Example for Neon (recommended): postgresql://user:pass@ep-example.us-east-1.aws.neon.tech/dbname
# Example for local: postgresql://postgres:password@localhost:5432/ayrshaer_cms
DATABASE_URL=postgresql://username:password@hostname:port/database_name

# Database Connection Pool Settings
# Maximum number of connections in the pool
DB_POOL_MAX=20

# Minimum number of connections in the pool  
DB_POOL_MIN=2

# Connection timeout in milliseconds
DB_TIMEOUT=30000

# =================================
# AUTHENTICATION CONFIGURATION
# =================================

# Replit OAuth Configuration
# Get these from: https://replit.com/account/organizations
REPLIT_CLIENT_ID=your_replit_client_id_here
REPLIT_CLIENT_SECRET=your_replit_client_secret_here

# Session Configuration
# Use a strong, random string (minimum 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your_super_secure_session_secret_minimum_32_characters

# Session Cookie Configuration
# Session timeout in milliseconds (default: 7 days)
SESSION_TIMEOUT=604800000

# Cookie security settings (set to true in production)
SESSION_SECURE=false

# =================================
# AI INTEGRATION (OPENAI)
# =================================

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Model Configuration
# Recommended: gpt-4o (latest model as of May 2024)
OPENAI_MODEL=gpt-4o

# OpenAI Request Timeout (milliseconds)
OPENAI_TIMEOUT=30000

# Maximum tokens per request
OPENAI_MAX_TOKENS=4000

# =================================
# PAYMENT PROCESSING (STRIPE)
# =================================

# Stripe API Keys
# Test keys start with pk_test_ and sk_test_
# Live keys start with pk_live_ and sk_live_
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Webhook Configuration
# Endpoint secret for webhook signature verification
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product Configuration
# Price IDs for subscription plans (get from Stripe dashboard)
STRIPE_PREMIUM_PRICE_ID=price_premium_subscription_id
STRIPE_BASIC_PRICE_ID=price_basic_subscription_id

# =================================
# EMAIL CONFIGURATION (OPTIONAL)
# =================================

# Email Service Configuration (for notifications)
# Provider options: sendgrid, mailgun, smtp
EMAIL_PROVIDER=sendgrid

# SendGrid Configuration (if using SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# =================================
# FILE STORAGE CONFIGURATION
# =================================

# File Upload Configuration
# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Storage Provider (local, aws-s3, cloudinary)
STORAGE_PROVIDER=local

# Local Storage Path (if using local storage)
UPLOAD_DIR=./uploads

# AWS S3 Configuration (if using S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Cloudinary Configuration (if using Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =================================
# LOGGING AND MONITORING
# =================================

# Log Level
# Options: error, warn, info, debug
LOG_LEVEL=info

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Sentry Configuration (for error tracking)
SENTRY_DSN=your_sentry_dsn_here

# Analytics Tracking
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# =================================
# SECURITY CONFIGURATION
# =================================

# CORS Configuration
# Allowed origins (comma-separated)
# Use "*" for development only, specify domains for production
CORS_ORIGINS=http://localhost:5000,https://your-domain.com

# Rate Limiting
# Requests per window per IP
RATE_LIMIT_REQUESTS=100
# Window duration in minutes
RATE_LIMIT_WINDOW=15

# Content Security Policy
# Set to 'strict' for production, 'relaxed' for development
CSP_MODE=relaxed

# =================================
# FEATURE FLAGS
# =================================

# AI Features
ENABLE_AI_CONTENT_GENERATION=true
ENABLE_PREDICTIVE_ANALYTICS=true
ENABLE_SENTIMENT_ANALYSIS=true

# Payment Features  
ENABLE_SUBSCRIPTIONS=true
ENABLE_ONE_TIME_PAYMENTS=false

# Beta Features
ENABLE_BETA_FEATURES=false

# =================================
# DEVELOPMENT CONFIGURATION
# =================================

# Enable debug logging
DEBUG=false

# Enable development tools
ENABLE_DEV_TOOLS=true

# Mock external services (useful for testing)
MOCK_OPENAI=false
MOCK_STRIPE=false
MOCK_EMAIL=false

# Test Database URL (for running tests)
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/ayrshaer_cms_test

# =================================
# PERFORMANCE CONFIGURATION
# =================================

# Redis Configuration (for caching, optional)
REDIS_URL=redis://localhost:6379

# Cache TTL in seconds
CACHE_TTL=3600

# Enable response compression
ENABLE_COMPRESSION=true

# Static file caching (in seconds)
STATIC_CACHE_DURATION=86400

# =================================
# MONITORING URLS
# =================================

# Health Check Endpoint
HEALTH_CHECK_PATH=/health

# Metrics Endpoint (for monitoring tools)
METRICS_PATH=/metrics

# =================================
# IMPORTANT SECURITY NOTES
# =================================

# 1. Never commit this file with real values to version control
# 2. Use Replit Secrets for production environment variables
# 3. Rotate secrets regularly, especially session secrets and API keys
# 4. Use environment-specific values (different keys for dev/prod)
# 5. Keep API keys and secrets with minimum required permissions
# 6. Monitor usage and set up alerts for unusual activity
# 7. Use HTTPS in production (handled automatically by Replit)
# 8. Regularly audit and update dependencies for security
